<main>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="page-container text-center">
      <h1 class="hero-title">Nomad Notes</h1>
      <p class="hero-tagline">Share Your Journey</p>
    </div>
  </section>

  <div class="page-container">
    <!-- Search Form -->
    <form class="mb-6 sm:mb-8 text-center" action="/">
      <label for="busqueda" class="block text-sm font-medium text-text mb-2">Search posts</label>
      <div class="flex flex-col sm:flex-row gap-2 max-w-md mx-auto">
        <input type="text" id="busqueda" name="busqueda" value="<%=busqueda%>"
               class="form-field flex-1 mb-0" placeholder="Search..."/>
        <button type="submit" class="btn btn-primary">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
           Search
        </button>
      </div>
    </form>

    <% if (publicaciones.length > 0) { %>
      <!-- Featured Post -->
      <% const featured = publicaciones[0]; %>
      <%- include('partials/post_card', { publicacion: featured, featured: true }) %>

      <!-- Post Grid -->
      <% if (publicaciones.length > 1) { %>
        <div class="post-grid">
          <% publicaciones.slice(1).forEach(publicacion => { %>
            <%- include('partials/post_card', { publicacion: publicacion, featured: false }) %>
          <% }) %>
        </div>
      <% } %>
    <% } else { %>
      <p class="text-text-muted text-center py-12">No posts found.</p>
    <% } %>

    <!-- Pagination -->
    <%- include('partials/pagination', { pagina: pagina, totalPages: totalPages }) %>
  </div>
</main>
