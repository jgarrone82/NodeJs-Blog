<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Blog Viajes</title>
  <link rel="stylesheet" href="/stylesheets/styles.css">
  <link rel="shortcut icon" type="image/png" href="images/favicon.png"/>
</head>

<body>
  <%- include('partials/encabezado_publico') %>

  <main class="page-container">
    <img src="images/fondo.jpg" class="hero-image" alt="Blog de Viajes">
    <h1 class="text-3xl font-bold mb-2">Inicio</h1>
    <p class="text-text-muted mb-6">Aquí nuestras últimas publicaciones:</p>

    <!-- Search Form -->
    <form class="mb-8 text-center" action="/">
      <label for="busqueda" class="block text-sm font-medium text-text mb-2">Buscar publicación</label>
      <div class="flex gap-2 max-w-md mx-auto">
        <input type="text" id="busqueda" name="busqueda" value="<%=busqueda%>" 
               class="form-field flex-1 mb-0" placeholder="Buscar..."/>
        <button type="submit" class="btn btn-primary">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          Buscar
        </button>
      </div>
    </form>

    <!-- Posts List -->
    <div class="space-y-6">
      <% publicaciones.forEach(publicacion => { %>
      <article class="post-card">
        <h3>
          <a href="/publicacion/<%=publicacion.id%>"><%=publicacion.titulo%></a>
          <span class="vote-badge"><%=publicacion.votos%></span>
        </h3>
        <div class="meta">
          <% if (publicacion.avatar && publicacion.avatar != "") { %>
            <img class="avatar" src="/avatars/<%=publicacion.avatar%>" alt="Avatar"/>
          <% } else { %>
            <svg class="w-4 h-4 inline-block align-middle text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <% } %>
          <%=publicacion.pseudonimo%> -
          <svg class="w-3 h-3 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <%= publicacion.fecha_hora.getFullYear() %>/<%= publicacion.fecha_hora.getMonth()+1 %>/<%= publicacion.fecha_hora.getDate() %>
        </div>
        <p class="excerpt"><%= publicacion.resumen %></p>
      </article>
      <% }) %>
    </div>

    <!-- Pagination -->
    <nav class="pagination">
      <a href="/?pagina=<%=pagina-1%>"><< Anterior</a>
      <span>|</span>
      <a href="/?pagina=<%=pagina+1%>">Siguiente >></a>
    </nav>
  </main>

  <%- include('partials/pie') %>
  <script src="/javascripts/script.js"></script>
</body>

</html>
