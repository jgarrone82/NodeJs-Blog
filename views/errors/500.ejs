<!DOCTYPE html>
<html lang="en">

<head>
  <script>(function(){var t=localStorage.getItem('theme');if(t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}})()</script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>500 — Internal Server Error</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/styles.css">
</head>

<body>
  <%- include('../partials/encabezado_publico') %>

  <main class="page-container flex items-center justify-center min-h-[60vh]">
    <div class="text-center px-4 w-full max-w-3xl">
      <h1 class="text-8xl font-bold text-red-600 mb-4 font-heading">500</h1>
      <h2 class="text-2xl font-semibold text-text mb-2">Internal Server Error</h2>
      <p class="text-text-muted mb-6">Something went wrong. We're working to fix it.</p>
      <% if (typeof message !== 'undefined' && message) { %>
        <p class="text-text mb-2"><%= message %></p>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <details class="text-left mt-4 bg-surface p-4 rounded-lg text-sm border border-border">
          <summary class="cursor-pointer font-semibold text-text">Technical Details</summary>
          <pre class="mt-2 text-red-600 overflow-x-auto text-xs"><%= error.stack %></pre>
        </details>
      <% } %>
      <a href="/" class="btn btn-primary inline-flex items-center gap-2 mt-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/></svg>
        Go Home
      </a>
    </div>
  </main>

  <%- include('../partials/pie') %>
</body>

</html>
