<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>500 — Error del servidor</title>
  <link rel="stylesheet" href="/stylesheets/styles.css">
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex items-center justify-center">
  <div class="text-center px-4">
    <h1 class="text-8xl font-bold text-red-600 mb-4">500</h1>
    <h2 class="text-2xl font-semibold text-gray-700 mb-2">Error interno del servidor</h2>
    <p class="text-gray-500 mb-6">Algo salió mal. Estamos trabajando en solucionarlo.</p>
    <% if (typeof message !== 'undefined' && message) { %>
      <p class="text-gray-600 mb-2"><%= message %></p>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <details class="text-left max-w-2xl mx-auto mt-4 bg-gray-100 p-4 rounded-lg text-sm">
        <summary class="cursor-pointer font-semibold text-gray-700">Detalles técnicos</summary>
        <pre class="mt-2 text-red-600 overflow-x-auto"><%= error.stack %></pre>
      </details>
    <% } %>
    <a href="/" class="inline-block bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors mt-6">
      Volver al inicio
    </a>
  </div>
</body>
</html>
