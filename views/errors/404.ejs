<% locals.title = '404 — Page Not Found' %>

<main class="page-container flex items-center justify-center min-h-[60vh]">
  <div class="text-center px-4">
    <h1 class="text-8xl font-bold text-primary mb-4 font-heading">404</h1>
    <h2 class="text-2xl font-semibold text-text mb-2">Page Not Found</h2>
    <p class="text-text-muted mb-6">The page you're looking for doesn't exist or was moved.</p>
    <% if (typeof url !== 'undefined' && url) { %>
      <p class="text-sm text-text-muted mb-6 font-mono"><%= url %></p>
    <% } %>
    <a href="/" class="btn btn-primary inline-flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/></svg>
      Go Home
    </a>
  </div>
</main>
