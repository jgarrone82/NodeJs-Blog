<header class="site-header" x-data="{ mobileNavOpen: false }">
  <div class="container mx-auto flex items-center justify-between px-3 sm:px-4">
    <a href="#" class="logo">Blog de Viajes</a>
    
    <!-- Mobile menu toggle -->
    <button @click="mobileNavOpen = !mobileNavOpen" class="menu-toggle" aria-label="Toggle navigation">
      <svg x-show="!mobileNavOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      <svg x-show="mobileNavOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display: none"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    
    <!-- Navigation -->
    <nav x-show="mobileNavOpen" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="-translate-y-2 opacity-0" x-transition:enter-end="translate-y-0 opacity-100" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="translate-y-0 opacity-100" x-transition:leave-end="-translate-y-2 opacity-0" class="mobile-nav absolute md:relative top-full left-0 right-0 md:top-auto md:left-auto md:right-auto shadow-lg md:shadow-none" @click.away="mobileNavOpen = false">
      <span class="flex items-center gap-1 px-4 py-3 text-sm border-t md:border-t-0 border-white/20">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        <%=usuario.pseudonimo%>
      </span>
      <a href="/admin/procesar_cerrar_sesion" class="flex items-center gap-1 px-4 py-3 text-sm hover:bg-primary-dark transition-colors border-t md:border-t-0 border-white/20">Cerrar Sesión</a>
      <a href="/admin/index" class="flex items-center gap-1 px-4 py-3 text-sm hover:bg-primary-dark transition-colors border-t md:border-t-0 border-white/20">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Admin
      </a>
    </nav>
  </div>
</header>
