<!-- Post Card Component -->
<!-- Usage: include('partials/post_card', { publicacion, featured: false, showExcerpt: true }) -->
<article class="group <%= featured ? 'featured-card' : 'post-card' %>">
  <!-- Image Placeholder -->
  <div class="card-image-placeholder overflow-hidden">
    <div class="card-image-inner">
      <svg class="w-8 h-8 text-text-muted/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
    </div>
  </div>

  <div class="p-3 sm:p-4 flex flex-col flex-1">
    <h3 class="<%= featured ? 'text-lg sm:text-xl' : 'text-base sm:text-lg' %> font-semibold leading-snug">
      <a href="/publicacion/<%=publicacion.id%>" class="text-text hover:text-primary transition-colors duration-200 dark:text-text-dark"><%=publicacion.titulo%></a>
      <span class="vote-badge"><%=publicacion.votos%></span>
    </h3>

    <div class="meta flex flex-wrap items-center gap-1.5 mt-2 text-xs sm:text-sm">
      <% if (publicacion.avatar && publicacion.avatar != "") { %>
        <img class="avatar" src="/avatars/<%=publicacion.avatar%>" alt="Avatar"/>
      <% } else { %>
        <svg class="w-4 h-4 inline-block align-middle text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      <% } %>
      <span class="font-medium"><%=publicacion.pseudonimo%></span>
      <span class="text-border hidden sm:inline">·</span>
      <span class="flex items-center gap-1 text-text-muted">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <%= publicacion.fecha_hora.getFullYear() %>/<%= String(publicacion.fecha_hora.getMonth()+1).padStart(2,'0') %>/<%= String(publicacion.fecha_hora.getDate()).padStart(2,'0') %>
      </span>
      <span class="text-border hidden sm:inline">·</span>
      <span class="text-text-muted"><%=publicacion.tiempo_lectura%> min read</span>
    </div>

    <% if (typeof showExcerpt === 'undefined' || showExcerpt) { %>
    <p class="excerpt mt-2 flex-1"><%= publicacion.resumen %></p>
    <% } %>
  </div>
</article>
