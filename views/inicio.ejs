<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Blog Viajes</title>
  <link rel="stylesheet" href="/stylesheets/styles.css">
  <link rel="shortcut icon" type="image/png" href="images/favicon.png"/>
</head>

<body>
  <%- include('./partials/encabezado_publico') %>

  <main class="page-container">
    <div class="max-w-md mx-auto">
      <h1 class="text-3xl font-bold mb-2">Inicio de Sesión</h1>
      <p class="text-text-muted mb-6">Ingresa tus credenciales para ingresar</p>

      <% if (mensaje && mensaje.length > 0) { %>
      <div class="alert alert-info">
        <svg class="w-5 h-5 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%=mensaje%>
      </div>
      <% } %>

      <form action="/procesar_inicio" method="POST" class="bg-surface p-6 rounded-lg shadow-md">
        <h2 class="text-lg font-semibold mb-4 pb-3 border-b border-border">Datos para entrar</h2>
        
        <div class="form-field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>
        
        <div class="form-field">
          <label for="contrasena">Contraseña</label>
          <input type="password" id="contrasena" name="contrasena" required />
        </div>
        
        <button type="submit" class="btn btn-primary w-full">Continuar</button>
      </form>
    </div>
  </main>

  <%- include('./partials/pie') %>
  <script src="/javascripts/script.js"></script>
</body>

</html>
